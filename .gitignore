# ─── Python / backend ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.eggs/
build/

# Caches tests / typage / lint
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ─── Node / Bun / frontend ─────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Environnement (secrets) ───────────────────────────────────
# On ignore tous les .env SAUF les .env.example (committés comme modèles)
.env
.env.*
!.env.example

# ─── IDE / éditeurs ────────────────────────────────────────────
.idea/
.vscode/
*.swp

# ─── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
